<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rage Ba!!: Precision Edition</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap');
        
        :root {
            --bg-dark: #020617;
            --accent-blue: #38bdf8;
            --accent-purple: #a855f7;
            --panel-bg: rgba(15, 23, 42, 0.7);
        }

        body {
            background-color: var(--bg-dark);
            color: #f8fafc;
            font-family: 'Outfit', sans-serif;
            margin: 0;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            touch-action: none;
        }

        #game-container {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            border: 2px solid rgba(255, 255, 255, 0.1);
            background: #000;
            box-shadow: 0 0 40px rgba(56, 189, 248, 0.2);
            display: flex;
        }

        canvas { display: block; cursor: crosshair; }

        .glass-panel {
            background: var(--panel-bg);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 16px;
            pointer-events: none;
            z-index: 10;
        }

        .stats-ui { position: absolute; top: 20px; left: 20px; min-width: 180px; }
        
        .sidebar-right {
            position: absolute;
            right: 15px;
            top: 20px;
            bottom: 20px;
            width: 40px;
            display: flex;
            flex-direction: column;
        }

        .map-container {
            flex-grow: 1;
            position: relative;
            background: rgba(15, 23, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            overflow: hidden;
        }

        .map-track {
            position: absolute;
            top: 20px;
            bottom: 20px;
            left: 50%;
            width: 2px;
            background: rgba(255, 255, 255, 0.1);
            transform: translateX(-50%);
        }

        .map-marker {
            position: absolute;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 10px;
            height: 10px;
            border-radius: 50%;
            transition: top 0.3s ease-out;
            box-shadow: 0 0 10px currentColor;
        }

        .high-score-marker {
            position: absolute;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 24px;
            height: 2px;
            background: #fde047;
            display: none;
        }
        
        .charge-meter {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 10px;
            background: rgba(255,255,255,0.1);
            border-radius: 5px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.2);
        }
        #charge-fill {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #38bdf8, #f43f5e);
            transition: width 0.05s linear;
        }

        .hazard-alert {
            position: absolute;
            top: 100px;
            left: 50%;
            transform: translateX(-50%);
            padding: 8px 24px;
            border-radius: 99px;
            background: rgba(168, 85, 247, 0.2);
            border: 1px solid var(--accent-purple);
            color: var(--accent-purple);
            font-weight: 900;
            opacity: 0;
            transition: all 0.3s ease;
            z-index: 20;
        }
        .active-alert { opacity: 1; transform: translateX(-50%) scale(1.1); }

        .red-herring-alert {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #f43f5e;
            font-weight: 900;
            font-size: 24px;
            pointer-events: none;
            text-transform: uppercase;
            letter-spacing: 5px;
            opacity: 0;
            transition: opacity 0.2s;
            text-shadow: 0 0 10px rgba(244, 63, 94, 0.8);
            z-index: 50;
        }
    </style>
</head>
<body>

    <div id="game-container">
        <div id="red-herring" class="red-herring-alert">! SYSTEM CRITICAL !</div>

        <div class="stats-ui glass-panel">
            <div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Altitude</div>
            <div class="text-3xl font-black italic text-white"><span id="height-val">0</span><span class="text-sm ml-1 text-slate-500">M</span></div>
            <div class="mt-2 text-xs text-sky-400 font-bold">Best: <span id="best-val">0</span>m</div>
        </div>

        <div class="sidebar-right">
            <div class="map-container">
                <div class="map-track"></div>
                <div id="best-marker" class="high-score-marker"></div>
                <div id="player-marker" class="map-marker" style="background: #38bdf8; color: #38bdf8; bottom: 20px; top: auto;"></div>
            </div>
        </div>

        <div id="space-indicator" class="hazard-alert">SPACE BOUND: 5X GRAVITY</div>

        <div class="charge-meter">
            <div id="charge-fill"></div>
        </div>

        <canvas id="gameCanvas"></canvas>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, getDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Global variables provided by the environment
        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'rage-jump-v1';

        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const heightDisplay = document.getElementById('height-val');
        const bestDisplay = document.getElementById('best-val');
        const chargeFill = document.getElementById('charge-fill');
        const spaceIndicator = document.getElementById('space-indicator');
        const playerMarker = document.getElementById('player-marker');
        const bestMarker = document.getElementById('best-marker');
        const herringAlert = document.getElementById('red-herring');

        let logoLoaded = false;
        const logoImg = new Image();
        logoImg.onload = () => { logoLoaded = true; };
        logoImg.src = 'image_99d627.jpg';

        canvas.width = 900; 
        canvas.height = 650;

        const BASE_GRAVITY = 0.28;
        const AIR_FRICTION = 0.99;
        const PLAYER_RADIUS = 10;
        const MAX_JUMP_FORCE = 11; 
        const FLOOR_Y = 500;
        const START_Y = FLOOR_Y - PLAYER_RADIUS;
        const ICE_THRESHOLD = 67000;
        const SPACE_THRESHOLD = 70000;
        const WORLD_MAX_HEIGHT = 80000; 

        const USELESS_FACTS = [
            "Saturn is less dense than water. It would float in a giant bathtub.",
            "Footprints on the Moon will stay there for 100 million years.",
            "There are more trees on Earth than stars in the Milky Way.",
            "Wombat poop is cube-shaped. Gravity has nothing to do with it.",
            "Hot water freezes faster than cold water.",
            "The moon smells like spent gunpowder.",
            "The heart of a shrimp is located in its head.",
            "Humans share 50% of their DNA with bananas.",
            "A cloud can weigh more than a million pounds.",
            "Bananas are technically berries, but strawberries aren't.",
            "Honey never spoils. Archaeologists have found edible 3,000-year-old honey.",
            "Pringles are not technically potato chips; they are 'crisps'."
        ];

        const FOOTBALL_QUOTES = [
            "\"I once cried because I had no shoes to play soccer, but one day, I met a man who had no feet.\" — Zinedine Zidane",
            "\"Success is no accident. It is hard work, perseverance, learning, studying, sacrifice.\" — Pelé",
            "\"You have to fight to reach your dream. You have to sacrifice and work hard for it.\" — Lionel Messi",
            "\"I don't mind people hating me, because it pushes me.\" — Cristiano Ronaldo",
            "\"I learned all about life with a ball at my feet.\" — Ronaldinho",
            "\"Your love makes me strong, your hate makes me unstoppable.\" — Cristiano Ronaldo",
            "\"To be a footballer, you must be a dreamer.\" — Neymar Jr",
            "\"Everything is possible. Even the word itself says 'I'm possible'!\" — Kylian Mbappé",
            "\"If you don't believe you are the best, then you will never achieve all that you are capable of.\" — Cristiano Ronaldo",
            "\"Winning – that's the most important to me. It's as simple as that.\" — Cristiano Ronaldo",
            "\"I start early and I stay late, day after day, year after year.\" — Lionel Messi",
            "\"There is no pressure when you are making a dream come true.\" — Neymar Jr"
        ];

        const RED_HERRING_MESSAGES = [
            "! SYSTEM CRITICAL !",
            "CALIBRATING...",
            "WIND SPEED: 200KM/H",
            "GRAVITY SHIFTING",
            "SENSORS OFFLINE",
            "BATTERY 1%",
            "UNAUTHORIZED JUMP"
        ];

        let seed = 12345;
        function seededRandom() {
            seed = (seed * 9301 + 49297) % 233280;
            return seed / 233280;
        }

        let player = { x: canvas.width / 2, y: START_Y, vx: 0, vy: 0, isGrounded: true, color: '#38bdf8' };
        let jumpCharge = 0;
        let isCharging = false;
        let bestHeight = 0;
        let currentAlt = 0;
        let cameraY = START_Y - 300;
        let mousePos = { x: 0, y: 0 };
        let platforms = [];
        let inGameFacts = [];
        let footballMilestones = [];
        let ghostPlatforms = [];
        let user = null;

        async function initAuth() {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                await signInWithCustomToken(auth, __initial_auth_token);
            } else {
                await signInAnonymously(auth);
            }
        }

        onAuthStateChanged(auth, async (u) => {
            user = u;
            if (user) {
                const docRef = doc(db, 'artifacts', appId, 'public', 'data', 'scores', user.uid);
                const snap = await getDoc(docRef);
                if (snap.exists()) {
                    bestHeight = snap.data().score;
                    bestDisplay.innerText = Math.floor(bestHeight);
                }
            }
        });

        async function updateScore(val) {
            if (!user || val <= bestHeight) return;
            bestHeight = val;
            bestDisplay.innerText = Math.floor(bestHeight);
            await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'scores', user.uid), {
                userId: user.uid,
                score: bestHeight
            });
        }

        function generateLevel() {
            seed = 12345;
            platforms = [];
            inGameFacts = [];
            footballMilestones = [];
            ghostPlatforms = [];
            platforms.push({ x: -1000, y: FLOOR_Y, w: 3000, h: 500, type: 'floor' });
            
            let lastX = canvas.width / 2;
            for (let i = 1; i < 20000; i++) {
                const yPos = FLOOR_Y - (i * 125); 
                const jumpRange = 250; 
                let nextX = lastX + (seededRandom() - 0.5) * jumpRange * 2;
                nextX = Math.max(120, Math.min(canvas.width - 240, nextX));
                
                platforms.push({ x: nextX, y: yPos, w: 80 + seededRandom() * 60, h: 12, type: 'normal' });
                
                if (i % 60 === 0) {
                    ghostPlatforms.push({
                        x: seededRandom() * 600 + 100,
                        y: yPos - 60,
                        w: 120,
                        h: 12
                    });
                }
                lastX = nextX;
            }

            for (let h = 500; h < 80000; h += 500) {
                if (h % 1000 === 0) continue; 
                const factY = FLOOR_Y - h;
                inGameFacts.push({
                    text: USELESS_FACTS[Math.floor(seededRandom() * USELESS_FACTS.length)],
                    x: seededRandom() * (canvas.width - 300) + 150,
                    y: factY
                });
            }

            for (let h = 1000; h < 80000; h += 1000) {
                const milY = FLOOR_Y - h;
                footballMilestones.push({
                    text: FOOTBALL_QUOTES[Math.floor(seededRandom() * FOOTBALL_QUOTES.length)],
                    x: canvas.width / 2,
                    y: milY,
                    alt: h/10
                });
            }
        }

        function updateUI() {
            const mapHeight = 100 - (currentAlt / WORLD_MAX_HEIGHT * 100);
            playerMarker.style.top = `${Math.max(5, Math.min(95, mapHeight))}%`;

            if (Math.random() < 0.005) {
                heightDisplay.innerText = Math.floor(Math.random() * 99999);
                setTimeout(() => { heightDisplay.innerText = currentAlt; }, 150);
            }

            if (Math.random() < 0.002) {
                herringAlert.innerText = RED_HERRING_MESSAGES[Math.floor(Math.random() * RED_HERRING_MESSAGES.length)];
                herringAlert.style.opacity = "0.8";
                setTimeout(() => { herringAlert.style.opacity = "0"; }, 1500);
            }
        }

        window.addEventListener('mousemove', e => {
            const rect = canvas.getBoundingClientRect();
            mousePos.x = (e.clientX - rect.left) * (canvas.width / rect.width);
            mousePos.y = (e.clientY - rect.top) * (canvas.height / rect.height) + cameraY;
        });

        window.addEventListener('mousedown', () => { if(player.isGrounded) isCharging = true; });
        window.addEventListener('mouseup', () => {
            if (isCharging) {
                const dx = mousePos.x - player.x;
                const dy = mousePos.y - player.y;
                const angle = Math.atan2(dy, dx);
                const power = (jumpCharge / 100) * MAX_JUMP_FORCE;
                player.vx = Math.cos(angle) * power;
                player.vy = Math.sin(angle) * power;
                player.isGrounded = false;
                isCharging = false;
                jumpCharge = 0;
                bestMarker.style.display = 'none'; 
            }
        });

        function reset() {
            if (bestHeight > 0) {
                const bestMapPos = 100 - (bestHeight / WORLD_MAX_HEIGHT * 100);
                bestMarker.style.top = `${Math.max(5, Math.min(95, bestMapPos))}%`;
                bestMarker.style.display = 'block';
            }
            player.x = canvas.width / 2;
            player.y = START_Y;
            player.vx = 0; player.vy = 0;
            player.isGrounded = true;
            cameraY = START_Y - 300;
        }

        function update() {
            currentAlt = Math.max(0, Math.floor((FLOOR_Y - player.y) / 10));
            if (Math.random() > 0.01) heightDisplay.innerText = currentAlt; 
            if (currentAlt > bestHeight) updateScore(currentAlt);

            updateUI();

            let gravity = BASE_GRAVITY;
            if (currentAlt >= SPACE_THRESHOLD) {
                gravity *= 5;
                spaceIndicator.classList.add('active-alert');
            } else {
                spaceIndicator.classList.remove('active-alert');
            }

            if (isCharging) {
                jumpCharge = Math.min(100, jumpCharge + 2.0);
                chargeFill.style.width = `${jumpCharge}%`;
            } else {
                chargeFill.style.width = '0%';
            }

            if (!player.isGrounded) {
                player.vy += gravity;
                player.vx *= AIR_FRICTION;
            } else {
                player.vx = (currentAlt >= ICE_THRESHOLD) ? player.vx * 0.985 : 0;
            }

            player.x += player.vx;
            player.y += player.vy;

            let foundGround = false;
            for (let p of platforms) {
                if (Math.abs(p.y - player.y) > 100) continue;
                if (player.vy >= 0 && player.y + PLAYER_RADIUS > p.y && player.y + PLAYER_RADIUS < p.y + p.h + 8 && player.x > p.x && player.x < p.x + p.w) {
                    player.y = p.y - PLAYER_RADIUS;
                    player.vy = 0;
                    foundGround = true;
                    break;
                }
            }
            player.isGrounded = foundGround;

            if (player.x < PLAYER_RADIUS) { player.x = PLAYER_RADIUS; player.vx *= -0.6; }
            if (player.x > canvas.width - PLAYER_RADIUS) { player.x = canvas.width - PLAYER_RADIUS; player.vx *= -0.6; }

            cameraY += (player.y - cameraY - 400) * 0.1;
            if (player.y > cameraY + 900) reset();
        }

        function draw() {
            ctx.fillStyle = currentAlt > SPACE_THRESHOLD ? '#000' : '#020617';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            ctx.save();
            ctx.translate(0, -cameraY);

            if (logoLoaded) {
                const targetWidth = 350;
                const scale = targetWidth / logoImg.width;
                ctx.drawImage(logoImg, canvas.width/2 - (logoImg.width*scale)/2, FLOOR_Y - (logoImg.height*scale) - 20, logoImg.width*scale, logoImg.height*scale);
            }

            ctx.textAlign = 'center';
            ctx.font = '700 13px Outfit';
            inGameFacts.forEach(f => {
                if (f.y < cameraY - 100 || f.y > cameraY + 750) return;
                ctx.fillStyle = 'rgba(148, 163, 184, 0.4)';
                ctx.fillText(f.text, f.x, f.y);
            });

            footballMilestones.forEach(m => {
                if (m.y < cameraY - 100 || m.y > cameraY + 750) return;
                ctx.font = '900 18px Outfit';
                ctx.fillStyle = '#fde047'; 
                ctx.shadowBlur = 10; ctx.shadowColor = '#fde047';
                ctx.fillText(m.text, m.x, m.y);
                ctx.shadowBlur = 0;

                ctx.font = '900 12px Outfit';
                ctx.fillStyle = 'rgba(253, 224, 71, 0.5)';
                ctx.fillText(`${m.alt} METER MARK`, m.x, m.y - 25);
            });

            ghostPlatforms.forEach(gp => {
                if (gp.y < cameraY - 100 || gp.y > cameraY + 750) return;
                ctx.fillStyle = 'rgba(56, 189, 248, 0.1)'; 
                ctx.fillRect(gp.x, gp.y, gp.w, gp.h);
                ctx.strokeStyle = 'rgba(56, 189, 248, 0.3)';
                ctx.strokeRect(gp.x, gp.y, gp.w, gp.h);
            });

            platforms.forEach(p => {
                if (p.y < cameraY - 100 || p.y > cameraY + 750) return;
                ctx.fillStyle = p.type === 'floor' ? '#0f172a' : '#1e293b';
                ctx.fillRect(p.x, p.y, p.w, p.h);
                ctx.fillStyle = currentAlt >= ICE_THRESHOLD && p.type !== 'floor' ? '#93c5fd' : '#0ea5e9';
                ctx.fillRect(p.x, p.y, p.w, 3);
            });

            if (isCharging) {
                const dx = mousePos.x - player.x;
                const dy = mousePos.y - player.y;
                const angle = Math.atan2(dy, dx);
                const power = (jumpCharge / 100) * MAX_JUMP_FORCE;
                ctx.beginPath();
                ctx.setLineDash([4, 6]);
                ctx.strokeStyle = 'rgba(56, 189, 248, 0.4)';
                let tx = player.x, ty = player.y, tvx = Math.cos(angle) * power, tvy = Math.sin(angle) * power;
                let tGrav = (currentAlt >= SPACE_THRESHOLD) ? BASE_GRAVITY * 5 : BASE_GRAVITY;
                ctx.moveTo(tx, ty);
                for(let i=0; i<45; i++) {
                    tx += tvx; ty += tvy; tvy += tGrav;
                    tvx *= AIR_FRICTION;
                    ctx.lineTo(tx, ty);
                }
                ctx.stroke();
                ctx.setLineDash([]);
            }

            ctx.shadowBlur = 15; ctx.shadowColor = player.color;
            ctx.fillStyle = player.color;
            ctx.beginPath(); ctx.arc(player.x, player.y, PLAYER_RADIUS, 0, Math.PI * 2); ctx.fill();
            ctx.restore();

            update();
            requestAnimationFrame(draw);
        }

        window.onload = () => {
            initAuth();
            generateLevel();
            draw();
        };
    </script>
</body>
</html>
